{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@billing-partner-portal/source"],
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      ":billing-partner-portal/portal-website": [
        "packages/portal-website/src/index.ts"
      ],
      ":billing-partner-portal/common-constructs": [
        "packages/common/constructs/src/index.ts"
      ],
      ":billing-partner-portal/infra": ["packages/infra/src/index.ts"]
    }
  }
}
