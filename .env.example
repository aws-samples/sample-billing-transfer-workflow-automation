# AWS Configuration
# The AWS region where your billing resources are deployed
AWS_REGION=us-east-1

# The 12-digit AWS account ID of your bill-receiver (distributor) account
# This is the account that receives transferred billing from customer accounts
AWS_ACCOUNT_ID=

# The AWS CLI profile name configured with credentials for the bill-receiver account
# Must have permissions for: Billing Conductor, Cost Explorer, BCM Data Exports, Athena, S3
AWS_PROFILE=

# Athena / Customer Reports
# These are used by the /customer-reports endpoint to query CUR data via Athena
# ATHENA_DATABASE: The Glue database containing your CUR table
# ATHENA_TABLE: The Glue table name for CUR 2.0 Parquet data
# ATHENA_RESULTS_BUCKET: S3 bucket for Athena query results (e.g., s3://my-athena-results)
ATHENA_DATABASE=billing_portal_cur
ATHENA_TABLE=cur_data
ATHENA_RESULTS_BUCKET=

# Bedrock Model
# The Bedrock model ID to use for the billing assistant
BEDROCK_MODEL_ID=

# MCP Server — AWS Billing & Cost Management MCP Server
# MCP_SERVER_VERSION: Pinned version of the MCP server (default: 0.1.5)
# MCP_TIMEOUT_SECONDS: Subprocess timeout in seconds (default: 30)
MCP_SERVER_VERSION=0.0.19
MCP_TIMEOUT_SECONDS=30

# CORS — comma-separated list of allowed origins for the agents service
# Set to your CloudFront domain after deployment (e.g., https://d1234abcdef.cloudfront.net)
# Defaults to http://localhost:4200,http://localhost:3000 for local dev
ALLOWED_ORIGINS=

# Bedrock Guardrails (optional — leave empty to skip guardrails for local dev)
# Set these after running `cdk deploy`, which creates the guardrail automatically
# BEDROCK_GUARDRAIL_ID: The guardrail ID from CDK output (e.g., abc123def456)
# BEDROCK_GUARDRAIL_VERSION: Use "DRAFT" for testing or a numeric version for production
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT
